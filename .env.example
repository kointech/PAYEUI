# ─────────────────────────────────────────────────────────────────────────────
# PAYE Developer Admin UI — environment variables
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# All VITE_* variables are bundled into the browser build.
# Never commit your real .env file to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── WalletConnect (EVM / RainbowKit) ─────────────────────────────────────────
# Get a free project ID at https://cloud.walletconnect.com
# Without this, WalletConnect QR-code is disabled; injected wallets still work.
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ── Linea Mainnet (chain ID 59144) ───────────────────────────────────────────
VITE_LINEA_RPC_URL=https://rpc.linea.build
VITE_LINEA_CONTRACT_MAIN=0xYourLineaMainTokenAddress
VITE_LINEA_CONTRACT_DEV=0xYourLineaDevTokenAddress

# ── Base Sepolia (chain ID 84532) ────────────────────────────────────────────
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
VITE_BASE_SEPOLIA_CONTRACT_MAIN=0xYourBaseSepoliaMainTokenAddress
VITE_BASE_SEPOLIA_CONTRACT_DEV=0xYourBaseSepoliaDevTokenAddress

# ── Ethereum Sepolia (chain ID 11155111) ─────────────────────────────────────
VITE_ETH_SEPOLIA_RPC_URL=https://rpc.sepolia.org
VITE_ETH_SEPOLIA_CONTRACT_MAIN=0xYourEthSepoliaMainTokenAddress
VITE_ETH_SEPOLIA_CONTRACT_DEV=0xYourEthSepoliaDevTokenAddress

# ── Solana ────────────────────────────────────────────────────────────────────
# Optional: override the default Solana Mainnet RPC endpoint.
# Default: https://api.mainnet-beta.solana.com
# For production use a dedicated RPC (Helius, QuickNode, Alchemy).
# VITE_SOLANA_MAINNET_RPC=https://mainnet.helius-rpc.com/?api-key=your_key_here

# Optional: override the default Solana Devnet RPC endpoint.
# Default: https://api.devnet.solana.com
# VITE_SOLANA_DEVNET_RPC=https://devnet.helius-rpc.com/?api-key=your_key_here
