# ─────────────────────────────────────────────────────────────────────────────
# PAYE Developer Admin UI — environment variables
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# All VITE_* variables are bundled into the browser build.
# Never commit your real .env file to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── WalletConnect (EVM / RainbowKit) ─────────────────────────────────────────
# Get a free project ID at https://cloud.walletconnect.com
# Without this, WalletConnect QR-code is disabled; injected wallets still work.
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id_here

# ── Linea Mainnet (chain ID 59144) ───────────────────────────────────────────
VITE_LINEA_RPC_URL=https://rpc.linea.build
VITE_LINEA_CONTRACT=0xYourLineaPayeTokenAddress

# ── Base Sepolia (chain ID 84532) ────────────────────────────────────────────
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
VITE_BASE_SEPOLIA_CONTRACT=0xYourBaseSepoliaPayeTokenAddress

# ── Ethereum Sepolia (chain ID 11155111) ─────────────────────────────────────
VITE_ETH_SEPOLIA_RPC_URL=https://rpc.sepolia.org
VITE_ETH_SEPOLIA_CONTRACT=0xYourEthSepoliaPayeTokenAddress

# ── Solana ────────────────────────────────────────────────────────────────────
# Mainnet cluster
# For production use a dedicated RPC (Helius, QuickNode, Alchemy).
VITE_SOLANA_MAINNET_RPC=https://api.mainnet-beta.solana.com
VITE_SOLANA_MAINNET_PROGRAM_ID=YourPayeOftProgramIdBase58Here
VITE_SOLANA_MAINNET_OFT_STORE=YourMainnetOftStorePdaBase58Here

# Devnet cluster
VITE_SOLANA_DEVNET_RPC=https://api.devnet.solana.com
VITE_SOLANA_DEVNET_PROGRAM_ID=YourPayeOftProgramIdBase58Here
VITE_SOLANA_DEVNET_OFT_STORE=YourDevnetOftStorePdaBase58Here
